# ---- Slack (sandbox workspace) ----
# Bot token (xoxb-): post messages + upload screenshots
SLACK_BOT_TOKEN=xoxb-...
# App-level token (xapp-): opens the Socket Mode websocket
SLACK_APP_TOKEN=xapp-...

# ---- Claude auth (pick ONE) ----
# Preferred: use your Pro/Max SUBSCRIPTION. Generate once on a machine with a
# browser: `claude setup-token` -> paste the long-lived OAuth token here.
# Runs on subscription rate limits, no per-token billing.
CLAUDE_CODE_OAUTH_TOKEN=
# Alternative: per-token API billing from console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Model used to drive QA sessions (sonnet is plenty for browser-driving)
QA_MODEL=claude-sonnet-4-6
# Hard ceiling on agent turns per run
CLAUDE_MAX_TURNS=60

# ---- GitHub (ephemeral create/teardown) ----
# gh reads GH_TOKEN automatically. Needs `repo` scope (+ org SSO authorization).
# Get yours with: gh auth token
GH_TOKEN=gho_...

# ---- Jira (ticket context for the QA agent) ----
# REST API via Basic auth (email + API token). Create a token at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://bookofthemonth.atlassian.net
JIRA_EMAIL=you@bookofthemonth.com
JIRA_API_TOKEN=ATATT...

# ---- QA target ----
# Fallback ephemeral URL when a mention doesn't include one
DEFAULT_EPHEMERAL_URL=
